// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // connection URL is configured in prisma.config.ts for Prisma v7+
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum EmployeeRole {
  STORE_ADMIN
  SUPER_ADMIN
}

enum DayName {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

enum PaymentMethod {
  MANUAL
  GATEWAY
}

enum PaymentStatus {
  SUCCESS
  PENDING
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  username  String?  @unique
  email     String   @unique
  password  String
  avatar    String?
  role      UserRole @default(CUSTOMER)
  
  referalCode String? @map("referal_code")
  
  emailVerifiedAt     DateTime?
  verificationToken   String?
  verificationExpires DateTime?

  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tokens    Token[]
  employee  Employee?
  addresses Address[]
  orders    orders[]
  carts     carts[]
}

model Token {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  device    String?
  ip        String?
  
  createdAt DateTime @default(now())
  expiredAt DateTime @map("expires_at")
}

model Branch {
  id                  String   @id @default(uuid())
  storeName           String   @map("store_name")
  address             String
  latitude            Float
  longitude           Float
  maxDeliveryDistance Float    @map("max_delivery_distance")
  isActive            Boolean  @default(true) @map("is_active")
  city                String
  province            String
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  schedules BranchSchedule[]
  employees Employee[]
  orders    orders[]
  carts     carts[]
}

model BranchSchedule {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  startTime String   @map("start_time") // Format HH:mm
  endTime   String   @map("end_time")   // Format HH:mm
  dayName   DayName  @map("day_name")
}

model Employee {
  id        String       @id @default(uuid())
  fullName  String       @map("full_name")
  role      EmployeeRole
  branchId  String       @map("branch_id")
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId    String?      @unique @map("user_id")
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Address {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  type        String
  receiptName String   @map("receipt_name")
  notes       String?
  phone       String
  address     String
  lat         Float
  long        Float
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  order     orders[]
}

model carts {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  branchId  String   @map("branch_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  
  items     cart_items[]

  @@map("carts")
}

model cart_items {
  id         String   @id @default(uuid())
  cartId     String   @map("cart_id")
  // productId  String   @map("product_id")
  // discountId String?  @map("discount_id")
  quantity   Int
  createdAt  DateTime @default(now()) @map("created_at")

  cart carts @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model orders {
  id              String   @id @default(uuid())
  orderNumber     String   @map("order_number")
  userId          String   @map("user_id")
  branchId        String   @map("branch_id")
  // discountId      String?  @map("discount_id")
  addressId       String   @map("address_id")
  status          String
  totalPrice      Float    @map("total_price")
  finalPrice      Float    @map("final_price")
  shippingCost    Float    @map("shipping_cost")
  paymentDeadline DateTime @map("payment_deadline")
  shippedAt       DateTime? @map("shipped_at")
  confirmedAt     DateTime? @map("confirmed_at")
  rejectedAt      DateTime? @map("rejected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  items    order_items[]
  payments payments[]

  @@map("orders")
}

model order_items {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  // productId  String  @map("product_id")
  // discountId String? @map("discount_id")
  price      Float
  quantity   Int

  order orders @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model payments {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  method     PaymentMethod
  status     PaymentStatus
  evidence   String?
  approvedBy String?  @map("approved_by")
  approvedAt DateTime? @map("approved_at")
  rejectedAt DateTime? @map("rejected_at")
  gatewayRef String?  @map("gateway_ref")
  createdAt  DateTime @default(now()) @map("created_at")

  order orders @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}